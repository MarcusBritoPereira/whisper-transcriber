# Configurações do Backend UPscribe

# Diretórios
UPLOAD_DIR=temp_uploads
RESULTS_DIR=results
DB_PATH=transcriptions.db

# Segurança e Limites
# API_KEYS=sua_chave_1,sua_chave_2
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_DOWNLOAD_DOMAINS=youtube.com,youtu.be,vimeo.com,tiktok.com
RATE_LIMIT_PER_MIN=20
MAX_FILE_MB=200

# Modelos e IA
DEFAULT_LANGUAGE=pt
# HF_TOKEN seu token do Hugging Face para habilitar diarização (pyannote)
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN=

# Abacate Pay Config
ABACATE_API_KEY=abc_dev_...
ABACATE_WEBHOOK_SECRET=sua_signature_secret_default
